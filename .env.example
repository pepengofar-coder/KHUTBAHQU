# Supabase (Frontend - Vite)
VITE_SUPABASE_URL=https://[YOUR_PROJECT].supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Supabase (Backend Serverless)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR_PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App Config
VITE_SITE_URL=https://islamediaku.vercel.app
NEXT_PUBLIC_SITE_URL=https://islamediaku.vercel.app

# Payment Settings
PAYMENT_PROVIDER=xendit_or_midtrans
ENABLE_MOCK_PAYMENT=true

# Xendit (Opsional - Jika payment_provider=xendit)
XENDIT_SECRET_KEY=xnd_...
XENDIT_WEBHOOK_TOKEN=...

# Midtrans (Opsional - Jika payment_provider=midtrans)
MIDTRANS_SERVER_KEY=SB-Mid-server-...
MIDTRANS_CLIENT_KEY=SB-Mid-client-...
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_WEBHOOK_SIGNATURE_KEY=...
